model User {
  id        String     @id @default(uuid())
  status    UserStatus
  role      UserRole
  name      String
  email     String     @unique
  password  String
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tasks     Task[]
  auditLogs AuditLog[]
}
