model AuditLog {
  id           String      @id @default(uuid())
  actor        User        @relation(fields: [actorId], references: [id])
  actorId      String
  actionType   AuditAction
  targetEntity String
  targetId     String
  summary      String?
  previousData Json?
  newData      Json?
  createdAt    DateTime    @default(now())
  task         Task?       @relation(fields: [taskId], references: [id])
  taskId       String?
}
